# ============================================================
#  MedLang — Environment Configuration
#  Barcha sozlamalar shu faylda. Haqiqiy .env faylini shu
#  asosda yarating: cp .env.example .env
# ============================================================

# ------------------------------------------------------------------
# Django Core
# ------------------------------------------------------------------
DJANGO_SECRET=change-me-use-python-secrets-token-hex-64
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.38.0.12
DJANGO_ADMIN_URL=secure-admin/

# ------------------------------------------------------------------
# PostgreSQL — Serverda mavjud PostgreSQL (Docker KERAK EMAS)
# Host:     localhost  (systemd postgres, port 5432)
# Ma'lumotlar bazasi: medlang_db
# Foydalanuvchi:      medlang_user
# ------------------------------------------------------------------
POSTGRES_DB=medlang_db
POSTGRES_USER=medlang_user
POSTGRES_PASSWORD=Medlang@2026#Secure!
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------------
# PostgreSQL — Admin foydalanuvchi (DB/user yaratishda ishlating)
# Faqat setup/migration paytida kerak.
# ------------------------------------------------------------------
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=

# ------------------------------------------------------------------
# Gunicorn / WSGI Server
# Port: 8090  (boshqa loyihalar: uzbeknlp=8000, cpp=8070)
# ------------------------------------------------------------------
GUNICORN_BIND=0.0.0.0:8090
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ------------------------------------------------------------------
# JWT (SimpleJWT)
# ------------------------------------------------------------------
JWT_EXP_MIN=60
JWT_REFRESH_DAYS=7

# ------------------------------------------------------------------
# Redis (optional — future Celery/cache support)
# Redis allaqachon serverdagi port 6379 da ishlaydi
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/1

# ------------------------------------------------------------------
# Static & Media
# ------------------------------------------------------------------
STATIC_ROOT=/var/www/medlang/staticfiles
MEDIA_ROOT=/var/www/medlang/media
MEDIA_URL=/media/

# ------------------------------------------------------------------
# Cors (agar frontend alohida domendan kelsa)
# ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------
# Sentry (optional — error tracking)
# ------------------------------------------------------------------
SENTRY_DSN=

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
LOG_LEVEL=WARNING
LOG_FILE=/var/log/medlang/app.log
